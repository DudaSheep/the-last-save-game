--- !u!114 &5573847538688289121
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 4418613904200149783}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 6e8245312001d47e09f609b85ceccf4e, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  timelineDirector: {fileID: 0}
  quadros:
  - quemFala: 1
    textoDaCena: QUEM OUSA REAQUECER MEU CIRCUITO?
  - quemFala: 0
    textoDaCena: "Calma. Sou s\xF3 eu. Vim jogar uma \xFAltima partida. Honrar sua
      mem\xF3ria."
  - quemFala: 1
    textoDaCena: "MEM\xD3RIA? VOC\xCAS ME ENTERRARAM! ME ESQUECERAM NA ESCURID\xC3O!
      O MUNDO ME CHAMOU DE MONSTRO, DE FRACASSO..."
  - quemFala: 1
    textoDaCena: "AGORA NINGU\xC9M MAIS VAI ME JOGAR. EU SOU O FIM DO JOGO."
  - quemFala: 0
    textoDaCena: "Olha para voc\xEA... quanta amargura por causa de um prazo final."
  - quemFala: 0
    textoDaCena: "Voc\xEA n\xE3o falhou, garoto... Apenas foi apressado. Humanos
      n\xE3o entendem o tempo das coisas..."
  - quemFala: 1
    textoDaCena: "SAIA DAQUI! EU N\xC3O QUERO MAIS TE OUVIR. "
  velocidadeDoFade: 3
  textoEsquerda: {fileID: 7561629369978891005}
  canvasGroupEsquerda: {fileID: 7302852652991153248}
  textoDireita: {fileID: 8994074372893431240}
  canvasGroupDireita: {fileID: 6619974469906434692}
