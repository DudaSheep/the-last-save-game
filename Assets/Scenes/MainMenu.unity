  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Atari E.T. (1982)\nLan\xE7ado para pegar carona no sucesso estrondoso
    do filme de Steven Spielberg, o jogo tinha a premissa l\xFAdica de ajudar o carism\xE1tico
    alien\xEDgena a coletar pe\xE7as de um telefone intergal\xE1ctico para \"ligar
    para casa\". Desenvolvido \xE0s pressas em apenas cinco semanas para o Natal,
    o t\xEDtulo chegou ao mercado repleto de bugs e com uma jogabilidade frustrante
    de quedas infinitas em buracos. O fracasso comercial foi t\xE3o colossal que
    resultou em milh\xF5es de cartuchos encalhados, enterrados em um deserto no Novo
    M\xE9xico, tornando-se o grande s\xEDmbolo do colapso da ind\xFAstria de jogos
    em 1983."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 08002e439d01f4f8b90473ce942ce2d0, type: 2}
  m_sharedMaterial: {fileID: -6677993086776333435, guid: 08002e439d01f4f8b90473ce942ce2d0, type: 2}
